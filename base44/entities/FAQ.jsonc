{
  "name": "FAQ",
  "type": "object",
  "properties": {
    "question": {
      "type": "string"
    },
    "answer": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "default": "General"
    },
    "order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "question",
    "answer"
  ]
}