{
  "name": "Testimonial",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "rating": {
      "type": "number",
      "default": 5
    },
    "review": {
      "type": "string"
    },
    "photo": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "review"
  ]
}